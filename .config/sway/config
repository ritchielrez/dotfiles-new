# Output configuration
output * bg /home/ritchiel/Pictures/artificial-valley.jpg fill
# exec ~/.azotebg

# Font
font pango:MartianMono Nerd Font 10

#
# GTK theming(not needed, just use nwg-look)
# GTK theming (not needed, just use nwg-look)
#
set $gnome-schema org.gnome.desktop.interface
seat seat0 xcursor_theme 'Bibata-Modern-Ice' 24
exec_always {
    gsettings set $gnome-schema gtk-theme 'catppuccin-mocha-mauve-standard+default'
    gsettings set $gnome-schema icon-theme 'Papirus-Dark'
    gsettings set $gnome-schema cursor-theme 'Bibata-Modern-Ice'
    gsettings set $gnome-schema cursor-size '24'
    gsettings set $gnome-schema font-name 'MartianMono Nerd Font 10'
    # gsettings set $gnome-schema text-scaling-factor 1.25
}

# Color scheme
include everforest

# Includes
include /etc/sway/config.d/*
include modules/input.conf
include modules/vars.conf
include modules/keymaps.conf
include modules/window.conf
include modules/autostart.conf
include modules/bar.conf
